{
    "name": "felixmuhoro/laravel-mpesa",
    "description": "Modern, fully-typed M-Pesa Daraja 2.0 integration for Laravel 10 / 11 / 12. STK Push, C2B, B2C, callbacks, events, and an exhaustive result-code dictionary — battle-tested in production.",
    "keywords": [
        "laravel",
        "mpesa",
        "daraja",
        "safaricom",
        "payments",
        "kenya",
        "stk-push",
        "lipa-na-mpesa",
        "c2b",
        "b2c"
    ],
    "homepage": "https://github.com/felixmuhoro/laravel-mpesa",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Felix Muhoro",
            "email": "hi@felixmuhoro.dev",
            "homepage": "https://felixmuhoro.dev",
            "role": "Developer"
        }
    ],
    "support": {
        "email": "hi@felixmuhoro.dev",
        "issues": "https://github.com/felixmuhoro/laravel-mpesa/issues",
        "source": "https://github.com/felixmuhoro/laravel-mpesa"
    },
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "FelixMuhoro\\Mpesa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FelixMuhoro\\Mpesa\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "FelixMuhoro\\Mpesa\\MpesaServiceProvider"
            ],
            "aliases": {
                "Mpesa": "FelixMuhoro\\Mpesa\\Facades\\Mpesa"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
